{
  "name": "eslint-plugin-dslint",
  "version": "0.1.0",
  "description": "Design System Lint - Enforce design token compliance in Tailwind CSS",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "bin": {
    "dslint": "./bin/dslint.js"
  },
  "files": [
    "dist",
    "bin"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --max-warnings 0"
  },
  "dependencies": {
    "commander": "^15.0.0",
    "css-tree": "^3.2.1"
  },
  "devDependencies": {
    "@types/css-tree": "^2.3.11",
    "@types/eslint": "^9.6.1",
    "@types/node": "^26.1.0",
    "tsup": "^8.5.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  },
  "peerDependencies": {
    "eslint": ">=9.0.0"
  },
  "keywords": [
    "eslint",
    "eslintplugin",
    "design-system",
    "tailwind",
    "lint",
    "design-tokens"
  ],
  "author": "Ryota Murakami",
  "license": "MIT"
}
