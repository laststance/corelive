{
  "name": "corelive",
  "version": "0.17.3",
  "description": "A comprehensive design system and web application built with Next.js, featuring authentication, database integration, and desktop support",
  "author": "Ryota Murakami <dojce1048@gmail.com> (https://github.com/ryota-murakami)",
  "private": true,
  "type": "module",
  "main": "dist-electron/main/index.cjs",
  "homepage": "./",
  "packageManager": "pnpm@10.33.4+sha512.1c67b3b359b2d408119ba1ed289f34b8fc3c6873412bec6fd264fbdc82489e510fcbecb9ce9d22dae7f3b76269d8441046014bdca53b9979cd7a561ad631b800",
  "volta": {
    "node": "24.13.0"
  },
  "lint-staged": {
    "*": "prettier --ignore-unknown --write",
    "*.{js,ts,jsx,tsx,cjs,mjs}": [
      "eslint --fix --max-warnings 0 --no-warn-ignored"
    ]
  },
  "scripts": {
    "postinstall": "pnpm prisma generate",
    "dev": "next dev -p 4991",
    "build": "next build --webpack",
    "build:icons": "node scripts/generate-icons.js",
    "prebuild": "pnpm build:icons",
    "start": "next start -p 4991",
    "lint": "cross-env NODE_OPTIONS=--max-old-space-size=8192 eslint . --concurrency=2 --max-warnings 0",
    "lint:fix": "cross-env NODE_OPTIONS=--max-old-space-size=8192 eslint . --fix --concurrency=2 --max-warnings 0",
    "test": "vitest run",
    "test:electron": "vitest run --config vitest.config.electron.ts",
    "test:electron:watch": "vitest --watch --config vitest.config.electron.ts",
    "test:storybook": "vitest run --config vitest.config.storybook.ts",
    "test:watch": "vitest --watch",
    "test:ui": "vitest --ui",
    "test:packages": "pnpm --filter eslint-plugin-dslint test",
    "coverage:unit:web": "vitest run --coverage",
    "coverage:unit:electron": "vitest run --config vitest.config.electron.ts --coverage",
    "coverage:unit": "pnpm coverage:unit:web && pnpm coverage:unit:electron",
    "coverage:e2e:electron": "rimraf coverage/.electron-v8 coverage/e2e-electron && cross-env COVERAGE=1 pnpm e2e:electron && node scripts/electron-coverage-report.mjs",
    "coverage:e2e:web": "rimraf coverage/e2e-web && cross-env COVERAGE=1 pnpm build && cross-env COVERAGE=1 playwright test --config=playwright.coverage.config.ts",
    "coverage:merge": "node scripts/coverage-merge.mjs",
    "coverage:all": "pnpm build:icons && pnpm coverage:unit && pnpm coverage:e2e:web && pnpm coverage:e2e:electron && pnpm coverage:merge",
    "theme:generate": "tsx scripts/generate-theme-css.ts",
    "theme:check": "tsx scripts/generate-theme-css.ts && git diff --exit-code src/lib/themes/generated.css && test -z \"$(git status --porcelain src/lib/themes/generated.css)\"",
    "prettier": "prettier --ignore-unknown --write .",
    "typecheck": "tsc --noEmit",
    "validate": "concurrently -n test,pkg,lint,build,type,theme -c blue,magenta,yellow,green,cyan,white --kill-others-on-fail \"pnpm test\" \"pnpm test:packages\" \"pnpm lint:fix\" \"pnpm build\" \"pnpm typecheck\" \"pnpm theme:check\"",
    "clean": "rimraf .next node_modules pnpm-lock.yaml tsconfig.tsbuildinfo dist dist-electron dist-electron-dev playwright-report tmp test-results storybook-static .playwright-mcp .playwright-cli monocart-report coverage .gstack",
    "prepare": "husky",
    "prisma:migrate": "node scripts/assert-local-db.cjs && cross-env PRISMA_USER_CONSENT_FOR_DANGEROUS_AI_ACTION=1 prisma migrate dev",
    "prisma:status": "cross-env PRISMA_USER_CONSENT_FOR_DANGEROUS_AI_ACTION=1 prisma migrate status",
    "prisma:deploy": "cross-env PRISMA_USER_CONSENT_FOR_DANGEROUS_AI_ACTION=1 prisma migrate deploy",
    "prisma:validate": "cross-env PRISMA_USER_CONSENT_FOR_DANGEROUS_AI_ACTION=1 prisma validate",
    "prisma:generate": "cross-env PRISMA_USER_CONSENT_FOR_DANGEROUS_AI_ACTION=1 prisma generate",
    "prisma:studio": "cross-env PRISMA_USER_CONSENT_FOR_DANGEROUS_AI_ACTION=1 prisma studio",
    "prisma:seed": "node scripts/assert-local-db.cjs && cross-env PRISMA_USER_CONSENT_FOR_DANGEROUS_AI_ACTION=1 tsx prisma/seed.ts",
    "seed:dev": "node scripts/assert-local-db.cjs && cross-env PRISMA_USER_CONSENT_FOR_DANGEROUS_AI_ACTION=1 tsx prisma/seed.dev.ts",
    "db:reset": "node scripts/assert-local-db.cjs && cross-env PRISMA_USER_CONSENT_FOR_DANGEROUS_AI_ACTION=1 prisma migrate reset --force && pnpm prisma:seed",
    "db:truncate": "node scripts/assert-local-db.cjs && cross-env PRISMA_USER_CONSENT_FOR_DANGEROUS_AI_ACTION=1 prisma migrate reset --force",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "e2e:web": "playwright test --project=web",
    "e2e:electron": "pnpm electron:build:ts && playwright test --config=playwright.electron.config.ts",
    "electron": "electron .",
    "preelectron:dev": "pnpm build:icons",
    "electron:dev": "node scripts/dev.js",
    "electron:build:ts": "electron-vite build",
    "preelectron:build:dir": "pnpm build:icons",
    "electron:build:mac": "pnpm electron:build:ts && electron-builder --mac --publish never && node scripts/finalize-mac-release-artifacts.js",
    "preelectron:build:mac": "pnpm build:icons",
    "electron:build:dir": "pnpm electron:build:ts && electron-builder --dir",
    "electron:publish": "pnpm electron:build:ts && electron-builder --publish=always",
    "preelectron:publish": "pnpm typecheck && pnpm test:electron --run"
  },
